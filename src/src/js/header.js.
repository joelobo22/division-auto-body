/**
 * @file header.js
 * @description Navigation, Sticky Header, and Scroll Spy for Division Auto Body.
 */

// 1. SELECTING ELEMENTS
const menuButton = document.querySelector(".menu-toggle");
const navigation = document.querySelector("nav.nav-primary");
const menuLinks = document.querySelectorAll(".primary-menu .menu-item a, a.top-link, .site-title a");
const navLinks = document.querySelectorAll(".nav-primary li.menu-item a");
const sections = document.querySelectorAll("main.entry-content section.section");

// 2. MOBILE NAVIGATION TOGGLE
if (menuButton && navigation) {
  menuButton.addEventListener("click", function () {
    // Toggle visibility
    navigation.classList.toggle("show");
    menuButton.classList.toggle("activated");
    menuButton.classList.toggle("bx-x");

    // Update ARIA states for accessibility
    const isExpanded = menuButton.getAttribute("aria-expanded") === "true";
    menuButton.setAttribute("aria-expanded", !isExpanded);
    menuButton.setAttribute("aria-pressed", !isExpanded);
  });
}

// 3. COLLAPSE MENU ON LINK CLICK
menuLinks.forEach((link) => {
  link.addEventListener("click", () => {
    navigation.classList.remove("show");
    menuButton.classList.remove("activated", "bx-x");
    menuButton.setAttribute("aria-expanded", "false");
    menuButton.setAttribute("aria-pressed", "false");
  });
});

// 4. STICKY HEADER & SCROLL SPY LOGIC
window.addEventListener("scroll", () => {
  const scrollPos = window.scrollY;

  // Header Dark Mode Trigger (Sticky effect)
  if (scrollPos >= 100) {
    document.body.classList.add("dark");
  } else {
    document.body.classList.remove("dark");
  }

  // Scroll Spy: Highlight active section in menu
  sections.forEach((section, i) => {
    const sectionTop = section.offsetTop - 150; // Offset for header height
    const sectionHeight = section.offsetHeight;
    const sectionId = section.getAttribute("id");

    if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
      navLinks.forEach((nav) => {
        nav.classList.remove("active");
        if (nav.getAttribute("href") === `#${sectionId}`) {
          nav.classList.add("active");
        }
      });
    }
  });
});

// 5. MANUAL ACTIVE STATE ON CLICK
navLinks.forEach((link) => {
  link.addEventListener("click", function() {
    navLinks.forEach((nav) => nav.classList.remove("active"));
    this.classList.add("active");
  });
});
