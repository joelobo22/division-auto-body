/**
 * @file src/js/testimonials.js
 * @description Testimonials for Division Auto Body - Collision & Restoration.
 */

// Array of testimonial objects custom to Division Auto Body
const alertBoxesData = [
  {
    url: `https://www.google.com/search?q=division+auto+body+keyport+reviews`,
    name: `Michael Ross`,
    body: `After my accident, I thought my truck was totaled. Division Auto Body handled the insurance and the repair perfectly. The paint match is flawless—you can't even tell where the damage was. Professional service that lives up to their 1977 reputation.`,
  },
  {
    url: `https://www.google.com/search?q=division+auto+body+keyport+reviews`,
    name: `Linda Howard`,
    body: `Best body shop in Keyport. They fixed a major dent in my door and had the car back to me earlier than promised. They are honest, fair, and the quality of work is top-tier. Highly recommend them for any collision needs.`,
  },
  {
    url: `https://www.google.com/search?q=division+auto+body+keyport+reviews`,
    name: `Jason Miller`,
    body: `I brought my classic Mustang in for some restoration paint work. These guys are true artists. They treated my car like it was their own. If you care about your car and want a high-end finish, bring it to Division.`,
  },
  {
    url: `https://www.google.com/search?q=division+auto+body+keyport+reviews`,
    name: `Sophia Reed`,
    body: `Division Auto Body made a stressful situation easy. They dealt with the insurance adjuster directly so I didn't have to. My SUV looks brand new again. Clean shop, friendly staff, and amazing results.`,
  },
  {
    url: `https://www.google.com/search?q=division+auto+body+keyport+reviews`,
    name: `Daniel Brooks`,
    body: `Expert craftsmanship. I've used them twice now for minor fender benders and both times the results were factory-perfect. You get what you pay for here: high-quality work and peace of mind.`,
  },
  {
    url: `https://www.google.com/search?q=division+auto+body+keyport+reviews`,
    name: `Emily Turner`,
    body: `I won't take my car anywhere else for body work. The staff is knowledgeable and they actually take the time to explain the repair process. Hard to find shops with this much integrity these days.`,
  },
];

const reviewerPics = import.meta.glob('../assets/media/reviewers/**/*', { eager: true });
import fallBackImg from '../assets/media/logo.svg';

const aletBoxHtml = alertBoxesData.map((rv) => {
  const {
    url = '',
    img = '',
    name = '',
    body = ''
  } = rv;
  const coverImage = reviewerPics[`../assets/media/reviewers/${img}`]?.default || fallBackImg;
  const avatar = img
    ? `<img decoding="async" loading="lazy" width="26" height="26" src="${coverImage}" class="rounded-circle" alt="Reviewer's Photo">`
    : `<i class='bx bx-user p-1 border rounded-circle text-primary'></i>`

  const output =
  `<li class="glide__slide h-auto">`+
      `<figure class="h-100 p-3 bg-dark border border-secondary shadow-sm">`+
        `<figcaption class="text-center text-md-start mb-2 fw-bold text-white">`+
          `<a href="${url}" title="5 star Google Review" rel="nofollow" class="text-white">`+
            `${avatar} ${name} &#8212; <i class="bx bxl-google text-primary"></i>`+
          `</a>`+
        `</figcaption>`+
        `<div class="star-ratings mb-2 text-center text-md-start text-primary">`+
          `<i class="bxs-star bx"></i>`+
          `<i class="bxs-star bx"></i>`+
          `<i class="bxs-star bx"></i>`+
          `<i class="bxs-star bx"></i>`+
          `<i class="bxs-star bx"></i>`+
        `</div>`+
        `<blockquote class="blockquote text-light" style="font-size: .875rem; font-style: italic;">"${body}"</blockquote>`+
      `</figure>`+
    `</li>`

  return output;
});

const aletBoxesElement = document.getElementById(`review-slides`)
if (aletBoxesElement) aletBoxesElement.innerHTML = aletBoxHtml.join(``)
