// Division Auto Body - Brand Colors
// Replacing blue with Racing Red

// Colors ---------
$primary: #d32f2f;    // Division Red
$secondary: #1a1a1a;  // Dark Gray
$info: #f4f4f4;
$danger: #ff0000;
$success: #28a745;
$dark: #0a0a0a;       // Deep Black
$light: #ffffff;      // Pure White

// Typography ------
$font-family-sans-serif: 'Inter Variable', sans-serif;
$headings-font-family: 'Montserrat Variable', sans-serif;
$btn-font-family: $headings-font-family;

// Custom Variables -----
$even-bg: #0f0f0f;
$odd-bg: #050505;

$box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.5);
$text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
$transition: all 0.3s ease-in-out;
