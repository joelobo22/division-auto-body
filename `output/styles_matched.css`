/* DIVISION AUTO BODY - BRAND STYLE GUIDE 2026
   Vibe: Luxury, Authority, 50-Year Legacy
*/

:root {
    --red: #d32f2f;
    --black: #0a0a0a;
    --white: #ffffff;
    --gray: #f4f4f4;
    --text-dark: #1a1a1a;
    --text-muted: #666666;
    --nav-height: 80px;
}

* {
    box-sizing: border-box;
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-color: var(--white);
    color: var(--text-dark);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
}

a {
    color: inherit;
    text-decoration: none;
}

img {
    max-width: 100%;
    display: block;
}

.container {
    width: min(1200px, calc(100% - 40px));
    margin: 0 auto;
}

.site-header {
    background: var(--black);
    color: var(--white);
    padding: 18px 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    border-bottom: 5px solid var(--red);
}

.site-header .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
}

.logo a {
    color: var(--white);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.95rem;
}

.nav-list {
    display: flex;
    list-style: none;
    gap: 18px;
    flex-wrap: wrap;
    justify-content: flex-end;
    margin: 0;
    padding: 0;
}

.nav-list a {
    color: var(--white);
    text-decoration: none;
    text-transform: uppercase;
    font-weight: 900;
    font-size: 0.82rem;
    letter-spacing: 2px;
    transition: color 0.3s ease;
}

.nav-list a:hover {
    color: var(--red);
}

.hero {
    background: linear-gradient(rgba(10, 10, 10, 0.72), rgba(10, 10, 10, 0.72)), url('images/hero-shop.jpg') center/cover no-repeat;
    color: var(--white);
    padding: 120px 0 110px;
    text-align: center;
}

.hero h1 {
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -3px;
    line-height: 0.85;
    margin: 0;
    text-transform: uppercase;
    color: var(--white);
}

.hero p {
    color: rgba(255,255,255,0.85);
    font-size: 1.05rem;
    margin: 12px auto 0;
    max-width: 760px;
}

.sub-header {
    color: var(--red);
    font-size: 1.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 5px;
    margin-top: 15px;
    display: block;
}

.cta-button,
.btn,
.btn-red {
    display: inline-block;
    background: var(--black);
    color: var(--white);
    padding: 18px 40px;
    text-decoration: none;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 2px;
    border: 2px solid var(--black);
    transition: all 0.4s ease;
    cursor: pointer;
    margin-top: 22px;
}

.cta-button:hover,
.btn:hover,
.btn-red:hover {
    background: transparent;
    color: var(--black);
}

.btn-red,
.cta-button {
    background: var(--red);
    border-color: var(--red);
}

section {
    padding: 90px 0;
}

section h2 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 900;
    letter-spacing: -1px;
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--black);
    margin-bottom: 20px;
}

section h3 {
    color: var(--black);
    margin: 28px 0 12px;
    font-size: 1.05rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1px;
}

section p {
    color: var(--text-dark);
    max-width: 78ch;
    margin-bottom: 16px;
}

.service-list,
.keywords-list,
.hours-list {
    margin: 18px 0 0;
    padding-left: 22px;
    color: var(--text-dark);
}

.service-list li,
.keywords-list li,
.hours-list li {
    margin-bottom: 10px;
}

.grid-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 20px;
}

.gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin: 34px 0;
}

.gallery-item {
    border: 1px solid #e3e3e3;
    overflow: hidden;
    background: var(--white);
    box-shadow: 0 12px 30px rgba(0,0,0,0.08);
}

.gallery-item img {
    width: 100%;
    height: 320px;
    object-fit: cover;
}

.gallery-cta {
    margin-top: 38px;
    text-align: center;
}

.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin: 34px 0;
}

.contact-info,
.email-cta {
    background: var(--gray);
    border: 1px solid #e3e3e3;
    padding: 30px;
}

.newsletter-form {
    margin-top: 16px;
}

.newsletter-form input {
    width: 100%;
    padding: 15px 16px;
    margin-bottom: 12px;
    border: 1px solid #d9d9d9;
    background: var(--white);
    color: var(--text-dark);
}

.location-strip {
    background: var(--black);
    color: var(--white);
    padding: 60px 20px;
    text-align: center;
}

.towns-list {
    max-width: 900px;
    margin: 0 auto;
    opacity: 0.7;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 2.2;
    text-transform: uppercase;
    letter-spacing: 1px;
}

footer {
    background: var(--black);
    color: var(--white);
    padding: 32px 0;
    text-align: center;
    font-size: 0.9rem;
    border-top: 5px solid var(--red);
}

footer p {
    margin: 4px 0;
}

#history,
#luxury,
#insurance,
#service-area,
#about,
#services,
#contact,
#fleet,
#contact-cta,
#high-end {
    background: var(--white);
}

@media (max-width: 768px) {
    .site-header .container {
        flex-direction: column;
        align-items: flex-start;
    }

    .nav-list {
        gap: 10px 14px;
        justify-content: flex-start;
    }

    .nav-list a {
        font-size: 0.72rem;
    }

    .hero {
        padding: 92px 0 82px;
    }

    .hero h1 {
        letter-spacing: -1px;
    }

    section {
        padding: 70px 0;
    }

    .contact-grid {
        grid-template-columns: 1fr;
    }

    .gallery-item img {
        height: 250px;
    }
}
