* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: Inter, "Helvetica Neue", Arial, sans-serif;
  line-height: 1.6;
  color: #edf1f5;
  background:
    radial-gradient(circle at top, rgba(212, 175, 55, 0.12), transparent 24%),
    linear-gradient(180deg, #050608 0%, #0b1016 42%, #050608 100%);
}

a { color: inherit; }

.container {
  width: min(1180px, calc(100% - 40px));
  margin: 0 auto;
}

.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(4, 6, 10, 0.78);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(255,255,255,0.08);
  padding: 18px 0;
}

.site-header .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18px;
}

.logo a {
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.22em;
  font-size: 0.9rem;
  font-weight: 700;
  color: #fff;
}

.nav-list {
  list-style: none;
  display: flex;
  gap: 22px;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.nav-list a {
  text-decoration: none;
  color: #cfd6de;
  font-size: 0.93rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.nav-list a:hover { color: #ffffff; }

.hero {
  position: relative;
  min-height: 92vh;
  display: flex;
  align-items: center;
  padding: 120px 0;
  color: #fff;
  background:
    linear-gradient(90deg, rgba(5, 6, 8, 0.96) 0%, rgba(5, 6, 8, 0.88) 42%, rgba(5, 6, 8, 0.35) 100%),
    url('images/hero-shop.jpg') center/cover no-repeat;
}

.hero .container {
  max-width: 860px;
}

.hero h1 {
  font-size: clamp(3rem, 8vw, 6.6rem);
  line-height: 0.92;
  margin-bottom: 18px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.hero p {
  font-size: 1.05rem;
  color: #d6dce3;
  max-width: 48rem;
  margin-bottom: 10px;
}

.cta-button {
  display: inline-block;
  margin-top: 28px;
  padding: 16px 30px;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: linear-gradient(135deg, #d8b76a 0%, #8a6b2f 100%);
  color: #090b0f;
  box-shadow: 0 16px 36px rgba(0,0,0,0.28);
}

.cta-button:hover { filter: brightness(1.04); }

section {
  padding: 110px 0;
}

section h2 {
  font-size: clamp(1.9rem, 3vw, 3rem);
  line-height: 1.02;
  margin-bottom: 18px;
  color: #ffffff;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

section h3 {
  color: #fff;
  margin: 26px 0 10px;
  font-size: 1.1rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

section p {
  margin-bottom: 16px;
  color: #c7cfd8;
  max-width: 72ch;
}

#history,
#luxury,
#insurance,
#service-area,
#about,
#services,
#contact,
#fleet,
#contact-cta,
#high-end {
  background: rgba(255,255,255,0.02);
  border-top: 1px solid rgba(255,255,255,0.06);
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.service-list,
.keywords-list,
.hours-list {
  margin: 18px 0 0;
  padding-left: 22px;
  color: #d6dce3;
}

.service-list li,
.keywords-list li,
.hours-list li {
  margin-bottom: 12px;
}

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 22px;
  margin: 34px 0;
}

.gallery-item {
  border-radius: 22px;
  overflow: hidden;
  background: #0f151d;
  border: 1px solid rgba(255,255,255,0.08);
  box-shadow: 0 24px 60px rgba(0,0,0,0.32);
}

.gallery-item img {
  width: 100%;
  height: 320px;
  object-fit: cover;
  display: block;
}

.gallery-cta {
  margin-top: 38px;
  text-align: center;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
  margin: 34px 0;
}

.contact-info,
.email-cta {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 24px;
  padding: 30px;
}

.contact-info h3,
.email-cta h3 {
  margin-top: 0;
}

.newsletter-form {
  margin-top: 16px;
}

.newsletter-form input {
  width: 100%;
  padding: 15px 16px;
  margin-bottom: 12px;
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 14px;
  background: rgba(255,255,255,0.04);
  color: #fff;
}

.newsletter-form input::placeholder { color: #8d97a4; }

footer {
  background: #040507;
  color: #b5bec8;
  padding: 38px 0;
  text-align: center;
  font-size: 0.92rem;
  border-top: 1px solid rgba(255,255,255,0.08);
}

footer p { margin: 4px 0; }

@media (max-width: 900px) {
  .hero { min-height: 76vh; padding: 92px 0; }
  .contact-grid { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .site-header .container {
    flex-direction: column;
    align-items: flex-start;
  }
  .nav-list {
    gap: 12px 18px;
    justify-content: flex-start;
  }
  .hero {
    background:
      linear-gradient(180deg, rgba(5, 6, 8, 0.96) 0%, rgba(5, 6, 8, 0.86) 100%),
      url('images/hero-shop.jpg') center/cover no-repeat;
  }
  section { padding: 76px 0; }
  .gallery-item img { height: 250px; }
}
